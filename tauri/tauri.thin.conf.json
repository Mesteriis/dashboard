{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Oko Thin",
  "version": "0.1.0",
  "identifier": "com.oko.dashboard.thin",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:desktop",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Oko — Your Infrastructure in Sight",
        "decorations": false,
        "width": 1560,
        "height": 960,
        "minWidth": 1080,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.icns", "icons/icon.png"],
    "resources": ["resources/dashboard.default.yaml"]
  }
}
